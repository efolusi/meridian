    {
      "path": "blocks/settings.html",
      "type": "registry:block",
      "content": "<!-- @dsCard group=\"Blocks\" viewport=\"1024x780\" name=\"Settings\" subtitle=\"Sectioned form page with danger zone\" -->\n<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><link rel=\"stylesheet\" href=\"../styles.css\">\n<script src=\"https://unpkg.com/react@18.3.1/umd/react.production.min.js\" integrity=\"sha384-DGyLxAyjq0f9SPpVevD6IgztCFlnMF6oW/XQGmfe+IsZ8TqEiDrcHkMLKI6fiB/Z\" crossorigin=\"anonymous\"></script>\n<script src=\"https://unpkg.com/react-dom@18.3.1/umd/react-dom.production.min.js\" integrity=\"sha384-gTGxhz21lVGYNMcdJOyq01Edg0jhn/c22nsx0kyqP0TxaV5WVdsSH1fSDUf5YJj1\" crossorigin=\"anonymous\"></script>\n<script src=\"https://unpkg.com/@babel/standalone@7.29.0/babel.min.js\" integrity=\"sha384-m08KidiNqLdpJqLq95G/LEi8Qvjl/xUYll3QILypMoQ65QorJ9Lvtp2RXYGBFj1y\" crossorigin=\"anonymous\"></script>\n<script src=\"../_ds_bundle.js\"></script>\n<style>@media(max-width:700px){.bk-row{grid-template-columns:1fr!important;gap:10px!important}.bk-main{padding:20px 16px 36px!important}}</style>\n</head><body style=\"background:var(--surface-page)\">\n<div id=\"root\"></div>\n<script type=\"text/babel\">\nconst { Button, Input, InputGroup, Select, Switch, Divider, Card, Tabs } = window.EfolusiDesignSystem_4ffc3d;\nfunction Row({ title, desc, children }) {\n  return (\n    <div className=\"bk-row\" style={{ display: 'grid', gridTemplateColumns: '260px 1fr', gap: 28, padding: '22px 0', borderBottom: '1px solid var(--border-default)', alignItems: 'start' }}>\n      <div>\n        <div style={{ fontSize: 14.5, fontWeight: 600 }}>{title}</div>\n        <div style={{ fontSize: 13, color: 'var(--text-muted)', marginTop: 4, lineHeight: 1.55 }}>{desc}</div>\n      </div>\n      <div style={{ maxWidth: 420 }}>{children}</div>\n    </div>\n  );\n}\nfunction Block() {\n  const [tab, setTab] = React.useState('general');\n  return (\n    <main className=\"bk-main\" style={{ padding: '28px 32px 48px', maxWidth: 880, margin: '0 auto' }}>\n      <h1 style={{ fontFamily: 'var(--font-display)', fontSize: 24, fontWeight: 650, letterSpacing: '-0.01em', margin: 0 }}>Workspace settings</h1>\n      <div style={{ marginTop: 14 }}>\n        <Tabs value={tab} onChange={setTab} items={[\n          { id: 'general', label: 'General' }, { id: 'members', label: 'Members', count: 38 },\n          { id: 'billing', label: 'Billing' }, { id: 'api', label: 'API' },\n        ]} />\n      </div>\n      <Row title=\"Workspace name\" desc=\"Shown in the sidebar and on invoices.\">\n        <Input defaultValue=\"Acme Ops\" />\n      </Row>\n      <Row title=\"Workspace URL\" desc=\"Changing this breaks existing links.\">\n        <InputGroup prefix=\"https://\" suffix=\".efolusi.com\" defaultValue=\"acme\" />\n      </Row>\n      <Row title=\"Default region\" desc=\"Where new agents run and data lives.\">\n        <Select options={['us-east-1', 'eu-west-1', 'ap-southeast-1']} defaultValue=\"eu-west-1\" />\n      </Row>\n      <Row title=\"Notifications\" desc=\"Digest and failure alerts for every member.\">\n        <div style={{ display: 'flex', flexDirection: 'column', gap: 10 }}>\n          <Switch defaultChecked label=\"Email on failed runs\" />\n          <Switch label=\"Weekly usage digest\" />\n        </div>\n      </Row>\n      <div style={{ display: 'flex', justifyContent: 'flex-end', gap: 10, padding: '18px 0' }}>\n        <Button variant=\"ghost\">Cancel</Button>\n        <Button>Save changes</Button>\n      </div>\n      <Card tone=\"danger\" title=\"Danger zone\" subtitle=\"These actions are permanent.\" padding={18} style={{ marginTop: 10 }}>\n        <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', gap: 18 }}>\n          <span style={{ fontSize: 13.5, color: 'var(--text-secondary)' }}>Delete this workspace and every agent, run, and artifact in it.</span>\n          <Button variant=\"danger\">Delete workspace</Button>\n        </div>\n      </Card>\n    </main>\n  );\n}\nReactDOM.createRoot(document.getElementById('root')).render(<Block />);\n</script></body></html>\n"
    }
  ],
  "categories": [
    "blocks"
  ],
  "$schema": "https://ui.shadcn.com/schema/registry-item.json"
}
