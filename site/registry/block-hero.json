      "content": "<!-- @dsCard group=\"Blocks\" viewport=\"1024x460\" name=\"Hero\" subtitle=\"Centered marketing hero with CTAs + social proof\" -->\n<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><link rel=\"stylesheet\" href=\"../styles.css\">\n<script src=\"https://unpkg.com/react@18.3.1/umd/react.production.min.js\" integrity=\"sha384-DGyLxAyjq0f9SPpVevD6IgztCFlnMF6oW/XQGmfe+IsZ8TqEiDrcHkMLKI6fiB/Z\" crossorigin=\"anonymous\"></script>\n<script src=\"https://unpkg.com/react-dom@18.3.1/umd/react-dom.production.min.js\" integrity=\"sha384-gTGxhz21lVGYNMcdJOyq01Edg0jhn/c22nsx0kyqP0TxaV5WVdsSH1fSDUf5YJj1\" crossorigin=\"anonymous\"></script>\n<script src=\"https://unpkg.com/@babel/standalone@7.29.0/babel.min.js\" integrity=\"sha384-m08KidiNqLdpJqLq95G/LEi8Qvjl/xUYll3QILypMoQ65QorJ9Lvtp2RXYGBFj1y\" crossorigin=\"anonymous\"></script>\n<script src=\"../_ds_bundle.js\"></script>\n<style>@media(max-width:600px){.bk-sec{padding:44px 18px 52px!important}.bk-h1{font-size:34px!important}}</style>\n</head><body style=\"background:var(--surface-page)\">\n<div id=\"root\"></div>\n<script type=\"text/babel\">\n\nconst { Button, Avatar, AvatarGroup } = window.EfolusiDesignSystem_4ffc3d;\nfunction Block() {\n  return (\n    <section className=\"bk-sec\" style={{ padding: '72px 48px 80px', textAlign: 'center' }}>\n      <div style={{ fontSize: 12, fontWeight: 600, letterSpacing: '0.08em', textTransform: 'uppercase', color: 'var(--text-muted)' }}>One workspace, every surface</div>\n      <h1 className=\"bk-h1\" style={{ fontFamily: 'var(--font-display)', fontSize: 56, fontWeight: 700, letterSpacing: '-0.02em', lineHeight: 1.05, margin: '16px auto 0', maxWidth: 680 }}>Ship the boring parts faster.</h1>\n      <p style={{ fontSize: 18, lineHeight: 1.6, color: 'var(--text-secondary)', margin: '18px auto 0', maxWidth: 480 }}>Agents, infrastructure, automation, and money: the parts every team rebuilds, already built.</p>\n      <div style={{ display: 'flex', gap: 10, justifyContent: 'center', marginTop: 26, flexWrap: 'wrap' }}>\n        <Button size=\"lg\" iconRight=\"arrow-right\">Start free</Button>\n        <Button size=\"lg\" variant=\"secondary\" iconLeft=\"book-open\">Read the docs</Button>\n      </div>\n      <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'center', gap: 12, marginTop: 26, flexWrap: 'wrap' }}>\n        <AvatarGroup><Avatar name=\"Ada Obi\" size={26} /><Avatar name=\"Femi Alade\" size={26} /><Avatar name=\"June Park\" size={26} /><Avatar name=\"Sol Reyes\" size={26} /></AvatarGroup>\n        <span style={{ fontSize: 13, color: 'var(--text-muted)' }}>4,200+ teams ship with Efolusi</span>\n      </div>\n    </section>\n  );\n}\nReactDOM.createRoot(document.getElementById('root')).render(<Block />);\n</script></body></html>\n"
