      "content": "<!-- @dsCard group=\"Blocks\" viewport=\"1024x600\" name=\"Login\" subtitle=\"Auth card: SSO, email + password, footer switch\" -->\n<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><link rel=\"stylesheet\" href=\"../styles.css\">\n<script src=\"https://unpkg.com/react@18.3.1/umd/react.production.min.js\" integrity=\"sha384-DGyLxAyjq0f9SPpVevD6IgztCFlnMF6oW/XQGmfe+IsZ8TqEiDrcHkMLKI6fiB/Z\" crossorigin=\"anonymous\"></script>\n<script src=\"https://unpkg.com/react-dom@18.3.1/umd/react-dom.production.min.js\" integrity=\"sha384-gTGxhz21lVGYNMcdJOyq01Edg0jhn/c22nsx0kyqP0TxaV5WVdsSH1fSDUf5YJj1\" crossorigin=\"anonymous\"></script>\n<script src=\"https://unpkg.com/@babel/standalone@7.29.0/babel.min.js\" integrity=\"sha384-m08KidiNqLdpJqLq95G/LEi8Qvjl/xUYll3QILypMoQ65QorJ9Lvtp2RXYGBFj1y\" crossorigin=\"anonymous\"></script>\n<script src=\"../_ds_bundle.js\"></script>\n</head><body style=\"background:var(--surface-page)\">\n<div id=\"root\"></div>\n<script type=\"text/babel\">\nconst { Button, Input, Divider, Checkbox, Link } = window.EfolusiDesignSystem_4ffc3d;\nfunction Block() {\n  return (\n    <main style={{ minHeight: '100vh', display: 'grid', placeItems: 'center', padding: 32 }}>\n      <div style={{ width: '100%', maxWidth: 380 }}>\n        <div style={{ display: 'flex', alignItems: 'center', gap: 10, justifyContent: 'center' }}>\n          <img src=\"../assets/logo.png\" alt=\"Efolusi\" style={{ width: 28, height: 28 }} />\n          <span style={{ fontFamily: 'var(--font-display)', fontWeight: 680, fontSize: 18, letterSpacing: '-0.02em' }}>Efolusi</span>\n        </div>\n        <h1 style={{ fontFamily: 'var(--font-display)', fontSize: 24, fontWeight: 650, letterSpacing: '-0.01em', textAlign: 'center', margin: '22px 0 0' }}>Welcome back</h1>\n        <p style={{ fontSize: 14, color: 'var(--text-secondary)', textAlign: 'center', margin: '8px 0 0' }}>Sign in to your workspace.</p>\n        <div style={{ background: 'var(--surface-card)', border: '1px solid var(--border-default)', borderRadius: 'var(--radius-lg)', padding: 24, marginTop: 22, display: 'flex', flexDirection: 'column', gap: 14 }}>\n          <Button variant=\"secondary\" fullWidth iconLeft=\"badge-check\">Continue with SSO</Button>\n          <Divider label=\"or\" />\n          <Input label=\"Work email\" type=\"email\" placeholder=\"ada@company.com\" iconLeft=\"mail\" autoComplete=\"off\" />\n          <Input label=\"Password\" type=\"password\" placeholder=\"\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\u2022\" iconLeft=\"lock\" autoComplete=\"off\" />\n          <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>\n            <Checkbox label=\"Remember me\" defaultChecked />\n            <Link href=\"#\">Forgot password?</Link>\n          </div>\n          <Button fullWidth>Sign in</Button>\n        </div>\n        <p style={{ fontSize: 13.5, color: 'var(--text-muted)', textAlign: 'center', marginTop: 18 }}>New to Efolusi? <Link href=\"#\">Create a workspace</Link></p>\n      </div>\n    </main>\n  );\n}\nReactDOM.createRoot(document.getElementById('root')).render(<Block />);\n</script></body></html>\n"
    }
  ],
