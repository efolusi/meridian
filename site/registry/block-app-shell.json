      "content": "<!-- @dsCard group=\"Blocks\" viewport=\"1280x620\" name=\"App shell\" subtitle=\"SideNav + TopNav + content scaffold\" -->\n<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><link rel=\"stylesheet\" href=\"../styles.css\">\n<script src=\"https://unpkg.com/react@18.3.1/umd/react.production.min.js\" integrity=\"sha384-DGyLxAyjq0f9SPpVevD6IgztCFlnMF6oW/XQGmfe+IsZ8TqEiDrcHkMLKI6fiB/Z\" crossorigin=\"anonymous\"></script>\n<script src=\"https://unpkg.com/react-dom@18.3.1/umd/react-dom.production.min.js\" integrity=\"sha384-gTGxhz21lVGYNMcdJOyq01Edg0jhn/c22nsx0kyqP0TxaV5WVdsSH1fSDUf5YJj1\" crossorigin=\"anonymous\"></script>\n<script src=\"https://unpkg.com/@babel/standalone@7.29.0/babel.min.js\" integrity=\"sha384-m08KidiNqLdpJqLq95G/LEi8Qvjl/xUYll3QILypMoQ65QorJ9Lvtp2RXYGBFj1y\" crossorigin=\"anonymous\"></script>\n<script src=\"../_ds_bundle.js\"></script>\n<style>@media(max-width:760px){.bk-side{display:none}}</style>\n</head><body style=\"background:var(--surface-page)\">\n<div id=\"root\"></div>\n<script type=\"text/babel\">\nconst { SideNav, TopNav, Breadcrumbs, Button, IconButton, Avatar, EmptyState } = window.EfolusiDesignSystem_4ffc3d;\nfunction Block() {\n  const [nav, setNav] = React.useState('runs');\n  return (\n    <div style={{ display: 'flex', height: '100vh', overflow: 'hidden' }}>\n      <div className=\"bk-side\" style={{ width: 232, flex: 'none', borderRight: '1px solid var(--border-default)' }}>\n        <SideNav brand=\"Acme Ops\" value={nav} onChange={setNav} groups={[\n          { items: [\n            { id: 'home', label: 'Overview', icon: 'house' },\n            { id: 'runs', label: 'Runs', icon: 'bot', badge: 3 },\n            { id: 'data', label: 'Data', icon: 'database' },\n            { id: 'billing', label: 'Billing', icon: 'credit-card' },\n          ] },\n          { label: 'Workspace', items: [\n            { id: 'members', label: 'Members', icon: 'users' },\n            { id: 'settings', label: 'Settings', icon: 'settings' },\n          ] },\n        ]} />\n      </div>\n      <div style={{ flex: 1, minWidth: 0, display: 'flex', flexDirection: 'column' }}>\n        <TopNav leading={<Breadcrumbs items={[{ label: 'Acme Ops', onClick: () => {} }, { label: 'Runs' }]} />}>\n          <IconButton variant=\"quiet\" icon=\"bell\" label=\"Notifications\" />\n          <Button size=\"sm\" iconLeft=\"plus\">New run</Button>\n          <Avatar name=\"Ada Obi\" size={28} />\n        </TopNav>\n        <main style={{ flex: 1, overflow: 'auto', padding: 28, display: 'grid', placeItems: 'center' }}>\n          <EmptyState bordered icon=\"bot\" title=\"No runs yet\"\n            description=\"Kick off your first agent run \u2014 it will show up here with live status.\"\n            action={<Button iconLeft=\"play\">Start a run</Button>} />\n        </main>\n      </div>\n    </div>\n  );\n}\nReactDOM.createRoot(document.getElementById('root')).render(<Block />);\n</script></body></html>\n"
    }
  ],
  "categories": [
