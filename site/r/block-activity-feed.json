      "content": "<!-- @dsCard group=\"Blocks\" viewport=\"1024x470\" name=\"Activity feed\" subtitle=\"Timeline of workspace events\" -->\n<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><link rel=\"stylesheet\" href=\"../styles.css\">\n<script src=\"https://unpkg.com/react@18.3.1/umd/react.development.js\" integrity=\"sha384-hD6/rw4ppMLGNu3tX5cjIb+uRZ7UkRJ6BPkLpg4hAu/6onKUg4lLsHAs9EBPT82L\" crossorigin=\"anonymous\"></script>\n<script src=\"https://unpkg.com/react-dom@18.3.1/umd/react-dom.development.js\" integrity=\"sha384-u6aeetuaXnQ38mYT8rp6sbXaQe3NL9t+IBXmnYxwkUI2Hw4bsp2Wvmx4yRQF1uAm\" crossorigin=\"anonymous\"></script>\n<script src=\"https://unpkg.com/@babel/standalone@7.29.0/babel.min.js\" integrity=\"sha384-m08KidiNqLdpJqLq95G/LEi8Qvjl/xUYll3QILypMoQ65QorJ9Lvtp2RXYGBFj1y\" crossorigin=\"anonymous\"></script>\n<script src=\"../_ds_bundle.js\"></script>\n<style>@media(max-width:600px){.bk-sec{padding:22px 12px!important}}</style>\n</head><body style=\"background:var(--surface-page)\">\n<div id=\"root\"></div>\n<script type=\"text/babel\">\n\nconst { Card, Avatar, Badge, Icon } = window.EfolusiDesignSystem_4ffc3d;\nconst EVENTS = [\n  ['Femi Alade', 'rotated the production API key', '2m ago', 'lock', null],\n  ['June Park', 'invited sam@acme.co as Admin', '18m ago', 'mail', null],\n  ['Ledger', 'invoice #10422 was paid', '1h ago', 'circle-check', ['success', '$1,240']],\n  ['Agent', 'completed \u201cSummarize churn drivers\u201d', '3h ago', 'sparkles', ['accent', '14 steps']],\n  ['Infra', 'worker-04 latency back to baseline', '5h ago', 'refresh-cw', null],\n];\nfunction Block() {\n  return (\n    <section className=\"bk-sec\" style={{ padding: '40px 48px', maxWidth: 640, margin: '0 auto' }}>\n      <Card padding={8} title=\"Activity\">\n        {EVENTS.map(([who, what, when, icon, badge], i) => (\n          <div key={i} style={{ display: 'flex', gap: 12, alignItems: 'flex-start', padding: '10px 12px', borderTop: i ? '1px solid var(--border-default)' : 'none' }}>\n            <span style={{ display: 'inline-flex', width: 28, height: 28, alignItems: 'center', justifyContent: 'center', flex: 'none', borderRadius: 'var(--radius-full)', background: 'var(--surface-sunken)', color: 'var(--text-secondary)' }}><Icon name={icon} size={14} /></span>\n            <div style={{ fontSize: 13.5, lineHeight: 1.45, flex: 1 }}>\n              <span style={{ fontWeight: 600 }}>{who}</span> <span style={{ color: 'var(--text-secondary)' }}>{what}</span>\n              <div style={{ fontSize: 11, color: 'var(--text-muted)', marginTop: 1 }}>{when}</div>\n            </div>\n            {badge && <Badge tone={badge[0]}>{badge[1]}</Badge>}\n          </div>\n        ))}\n      </Card>\n    </section>\n  );\n}\nReactDOM.createRoot(document.getElementById('root')).render(<Block />);\n</script></body></html>\n"
    }
  ],
