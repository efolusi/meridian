      "content": "<!-- @dsCard group=\"Blocks\" viewport=\"1024x420\" name=\"FAQ\" subtitle=\"Accordion FAQ on a text measure\" -->\n<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><link rel=\"stylesheet\" href=\"../styles.css\">\n<script src=\"https://unpkg.com/react@18.3.1/umd/react.production.min.js\" integrity=\"sha384-DGyLxAyjq0f9SPpVevD6IgztCFlnMF6oW/XQGmfe+IsZ8TqEiDrcHkMLKI6fiB/Z\" crossorigin=\"anonymous\"></script>\n<script src=\"https://unpkg.com/react-dom@18.3.1/umd/react-dom.production.min.js\" integrity=\"sha384-gTGxhz21lVGYNMcdJOyq01Edg0jhn/c22nsx0kyqP0TxaV5WVdsSH1fSDUf5YJj1\" crossorigin=\"anonymous\"></script>\n<script src=\"https://unpkg.com/@babel/standalone@7.29.0/babel.min.js\" integrity=\"sha384-m08KidiNqLdpJqLq95G/LEi8Qvjl/xUYll3QILypMoQ65QorJ9Lvtp2RXYGBFj1y\" crossorigin=\"anonymous\"></script>\n<script src=\"../_ds_bundle.js\"></script>\n<style>@media(max-width:600px){.bk-sec{padding:30px 16px!important}}</style>\n</head><body style=\"background:var(--surface-page)\">\n<div id=\"root\"></div>\n<script type=\"text/babel\">\n\nconst { Accordion } = window.EfolusiDesignSystem_4ffc3d;\nfunction Block() {\n  return (\n    <section className=\"bk-sec\" style={{ padding: '48px 40px', maxWidth: 720, margin: '0 auto' }}>\n      <h2 style={{ fontFamily: 'var(--font-display)', fontSize: 30, fontWeight: 680, letterSpacing: '-0.02em', margin: '0 0 20px' }}>Questions, answered</h2>\n      <Accordion defaultOpen={['billing']} items={[\n        { id: 'billing', title: 'How does billing work?', content: 'Per seat, monthly. Usage is metered daily and invoiced on the 1st. No usage cliffs, no surprise line items.' },\n        { id: 'security', title: 'Is Efolusi SOC 2 compliant?', content: 'Yes \u2014 SOC 2 Type II, with SSO and SCIM on Scale. Reports available under NDA.' },\n        { id: 'cancel', title: 'Can I cancel anytime?', content: 'Yes. Your workspace stays readable forever; only writes stop.' },\n        { id: 'migrate', title: 'Can you help us migrate?', content: 'Growth and Scale include guided migration from your current stack \u2014 usually under a week.' },\n      ]} />\n    </section>\n  );\n}\nReactDOM.createRoot(document.getElementById('root')).render(<Block />);\n</script></body></html>\n"
    }
