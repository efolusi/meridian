{
  "name": "block-pricing",
  "type": "registry:block",
  "title": "Pricing block",
  "description": "Pre-composed Meridian section: pricing.",
  "files": [
    {
      "path": "blocks/pricing.html",
      "type": "registry:block",
      "content": "<!-- @dsCard group=\"Blocks\" viewport=\"1024x560\" name=\"Pricing\" subtitle=\"Three-tier pricing with popular highlight\" -->\n<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><link rel=\"stylesheet\" href=\"../styles.css\">\n<script src=\"https://unpkg.com/react@18.3.1/umd/react.development.js\" integrity=\"sha384-hD6/rw4ppMLGNu3tX5cjIb+uRZ7UkRJ6BPkLpg4hAu/6onKUg4lLsHAs9EBPT82L\" crossorigin=\"anonymous\"></script>\n<script src=\"https://unpkg.com/react-dom@18.3.1/umd/react-dom.development.js\" integrity=\"sha384-u6aeetuaXnQ38mYT8rp6sbXaQe3NL9t+IBXmnYxwkUI2Hw4bsp2Wvmx4yRQF1uAm\" crossorigin=\"anonymous\"></script>\n<script src=\"https://unpkg.com/@babel/standalone@7.29.0/babel.min.js\" integrity=\"sha384-m08KidiNqLdpJqLq95G/LEi8Qvjl/xUYll3QILypMoQ65QorJ9Lvtp2RXYGBFj1y\" crossorigin=\"anonymous\"></script>\n<script src=\"../_ds_bundle.js\"></script>\n<style>@media(max-width:860px){.bk-tiers{grid-template-columns:1fr!important}}@media(max-width:600px){.bk-sec{padding:36px 16px!important}.bk-h2{font-size:26px!important}}</style>\n</head><body style=\"background:var(--surface-page)\">\n<div id=\"root\"></div>\n<script type=\"text/babel\">\n\nconst { Card, Badge, Button, Icon } = window.EfolusiDesignSystem_4ffc3d;\nconst TIERS = [\n  ['Starter', '$0', 'For side projects', ['1 product', '2 seats', '10k requests/mo'], 'secondary'],\n  ['Growth', '$12', 'Per seat \u2014 most teams start here', ['All 6 products', 'Unlimited seats', '1M requests/mo', 'SSO'], 'primary'],\n  ['Scale', 'Custom', 'For platforms & regulated teams', ['Everything in Growth', 'Unlimited requests', 'SCIM & audit log'], 'brand'],\n];\nfunction Block() {\n  return (\n    <section className=\"bk-sec\" style={{ padding: '48px 40px' }}>\n      <h2 className=\"bk-h2\" style={{ fontFamily: 'var(--font-display)', fontSize: 34, fontWeight: 680, letterSpacing: '-0.02em', textAlign: 'center', margin: 0 }}>Pricing that stays boring</h2>\n      <div className=\"bk-tiers\" style={{ display: 'grid', gridTemplateColumns: '1fr 1fr 1fr', gap: 18, marginTop: 32 }}>\n        {TIERS.map(([name, price, desc, feats, cta]) => (\n          <Card key={name} padding={24} style={cta === 'primary' ? { borderColor: 'var(--accent)' } : {}}>\n            <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>\n              <h3 style={{ fontSize: 17, fontWeight: 700, margin: 0 }}>{name}</h3>\n              {cta === 'primary' && <Badge tone=\"accent\">Popular</Badge>}\n            </div>\n            <div style={{ display: 'flex', alignItems: 'baseline', gap: 6, marginTop: 12 }}>\n              <span style={{ fontFamily: 'var(--font-display)', fontSize: 34, fontWeight: 680, letterSpacing: '-0.02em' }}>{price}</span>\n              {price === '$12' && <span style={{ fontSize: 12, color: 'var(--text-muted)' }}>/seat/mo</span>}\n            </div>\n            <p style={{ fontSize: 13, color: 'var(--text-muted)', margin: '4px 0 0' }}>{desc}</p>\n            <div style={{ display: 'flex', flexDirection: 'column', gap: 8, margin: '18px 0 20px' }}>\n              {feats.map(f => <span key={f} style={{ display: 'flex', gap: 8, alignItems: 'center', fontSize: 13.5 }}><span style={{ color: 'var(--sand-600)', display: 'inline-flex' }}><Icon name=\"check\" size={14} /></span>{f}</span>)}\n            </div>\n            <Button fullWidth variant={cta} iconRight=\"arrow-right\">{price === 'Custom' ? 'Talk to us' : 'Start free'}</Button>\n          </Card>\n        ))}\n      </div>\n    </section>\n  );\n}\nReactDOM.createRoot(document.getElementById('root')).render(<Block />);\n</script></body></html>\n"
    }
  ],
  "categories": [
    "blocks"
  ],
  "$schema": "https://ui.shadcn.com/schema/registry-item.json"
}
