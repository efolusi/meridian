     <Input placeholder=\"Search efolusi.com\u2026\" iconLeft=\"search\" style={{ flex: 1 }} />\n        <Button>Search</Button>\n      </div>\n      <div style={{ display: 'flex', gap: 8, justifyContent: 'center', marginTop: 14, alignItems: 'center', fontSize: 13, color: 'var(--text-muted)', flexWrap: 'wrap' }}>\n        or press <Kbd>\u2318</Kbd><Kbd>K</Kbd> anywhere \u00b7 <a href=\"#\" style={{ fontWeight: 600 }}>Back to home</a>\n      </div>\n    </section>\n  );\n}\nReactDOM.createRoot(document.getElementById('root')).render(<Block />);\n</script></body></html>\n"
