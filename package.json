{
  "name": "meridian-build",
  "version": "1.5.2",
  "private": true,
  "description": "Build tooling for the Meridian design system. Not the published package \u2014 consumers use the CDN or vendor the folder; see README.md.",
  "type": "module",
  "scripts": {
    "build:bundle": "node scripts/build_bundle.mjs",
    "build:npm": "node scripts/build_npm.mjs",
    "check": "node scripts/check_all.mjs",
    "check:bundle": "node scripts/build_bundle.mjs --check",
    "check:fix": "node scripts/check_all.mjs --fix",
    "check:npm": "node scripts/build_npm.mjs --check",
    "check:types": "node scripts/check_types.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@babel/standalone": "7.29.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
