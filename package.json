{
  "name": "meridian-build",
  "private": true,
  "description": "Build tooling for the Meridian design system. Not the published package — consumers use the CDN or vendor the folder; see README.md.",
  "type": "module",
  "scripts": {
    "build:bundle": "node scripts/build_bundle.mjs",
    "check:bundle": "node scripts/build_bundle.mjs --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:npm": "node scripts/build_npm.mjs",
    "check:npm": "node scripts/build_npm.mjs --check"
  },
  "devDependencies": {
    "@babel/standalone": "7.29.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vitest": "^2.1.9"
  }
}
