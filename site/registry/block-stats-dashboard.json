  "description": "Pre-composed Meridian section: stats dashboard.",
  "files": [
    {
      "path": "blocks/stats-dashboard.html",
      "type": "registry:block",
      "content": "<!-- @dsCard group=\"Blocks\" viewport=\"1280x660\" name=\"Stats dashboard\" subtitle=\"KPI row, trend chart, top-agents table\" -->\n<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><link rel=\"stylesheet\" href=\"../styles.css\">\n<script src=\"https://unpkg.com/react@18.3.1/umd/react.development.js\" integrity=\"sha384-hD6/rw4ppMLGNu3tX5cjIb+uRZ7UkRJ6BPkLpg4hAu/6onKUg4lLsHAs9EBPT82L\" crossorigin=\"anonymous\"></script>\n<script src=\"https://unpkg.com/react-dom@18.3.1/umd/react-dom.development.js\" integrity=\"sha384-u6aeetuaXnQ38mYT8rp6sbXaQe3NL9t+IBXmnYxwkUI2Hw4bsp2Wvmx4yRQF1uAm\" crossorigin=\"anonymous\"></script>\n<script src=\"https://unpkg.com/@babel/standalone@7.29.0/babel.min.js\" integrity=\"sha384-m08KidiNqLdpJqLq95G/LEi8Qvjl/xUYll3QILypMoQ65QorJ9Lvtp2RXYGBFj1y\" crossorigin=\"anonymous\"></script>\n<script src=\"../_ds_bundle.js\"></script>\n<style>@media(max-width:900px){.bk-kpis{grid-template-columns:1fr 1fr!important}.bk-panels{grid-template-columns:1fr!important}}@media(max-width:560px){.bk-kpis{grid-template-columns:1fr!important}.bk-main{padding:16px!important}}</style>\n</head><body style=\"background:var(--surface-page)\">\n<div id=\"root\"></div>\n<script type=\"text/babel\">\nconst { Card, Stat, BarChart, Table, Badge, Button, SegmentedControl } = window.EfolusiDesignSystem_4ffc3d;\nfunction Block() {\n  const [range, setRange] = React.useState('30d');\n  return (\n    <main className=\"bk-main\" style={{ padding: 28, maxWidth: 1160, margin: '0 auto' }}>\n      <div style={{ display: 'flex', alignItems: 'center', gap: 12, flexWrap: 'wrap', rowGap: 10 }}>\n        <h1 style={{ fontFamily: 'var(--font-display)', fontSize: 24, fontWeight: 650, letterSpacing: '-0.01em', margin: 0 }}>Overview</h1>\n        <div style={{ marginLeft: 'auto', display: 'flex', gap: 10 }}>\n          <SegmentedControl value={range} onChange={setRange} options={[{ id: '7d', label: '7d' }, { id: '30d', label: '30d' }, { id: '90d', label: '90d' }]} />\n          <Button variant=\"secondary\" size=\"sm\" iconLeft=\"arrow-down-right\">Export</Button>\n        </div>\n      </div>\n      <div className=\"bk-kpis\" style={{ display: 'grid', gridTemplateColumns: 'repeat(4,1fr)', gap: 14, marginTop: 18 }}>\n        <Card padding={16}><Stat label=\"Total runs\" value=\"12,480\" delta=\"+12.4%\" direction=\"up\" hint=\"vs previous period\" /></Card>\n        <Card padding={16}><Stat label=\"Success rate\" value=\"98.2%\" delta=\"+0.4pt\" direction=\"up\" /></Card>\n        <Card padding={16}><Stat label=\"P95 latency\" value=\"212 ms\" delta=\"\u22128 ms\" direction=\"down\" /></Card>\n        <Card padding={16}><Stat label=\"Spend\" value=\"$4,820\" delta=\"+6.1%\" direction=\"up\" hint=\"of $6,000 budget\" /></Card>\n      </div>\n      <div className=\"bk-panels\" style={{ display: 'grid', gridTemplateColumns: '1.4fr 1fr', gap: 14, marginTop: 14 }}>\n        <Card title=\"Runs per week\" padding={18}>\n          <BarChart height={170} highlightLast={1} labels={['W1','W2','W3','W4','W5','W6','W7','W8']} data={[820, 940, 1010, 890, 1180, 1260, 1340, 1520]} />\n        </Card>\n        <Card title=\"Top agents\" padding={0}>\n          <Table rowKey=\"id\" columns={[\n            { key: 'name', label: 'Agent' },\n            { key: 'runs', label: 'Runs', numeric: true, align: 'right' },\n            { key: 'status', label: 'Status', render: (v) => <Badge tone={v === 'Live' ? 'success' : 'neutral'} dot={v === 'Live'}>{v}</Badge> },\n          ]} rows={[\n            { id: 'a', name: 'Inbox triager', runs: 4120, status: 'Live' },\n            { id: 'b', name: 'Flight rebooking', runs: 1280, status: 'Live' },\n            { id: 'c', name: 'Refund handler', runs: 960, status: 'Live' },\n            { id: 'd', name: 'Weekly digest', runs: 340, status: 'Paused' },\n          ]} />\n        </Card>\n      </div>\n    </main>\n  );\n}\nReactDOM.createRoot(document.getElementById('root')).render(<Block />);\n</script></body></html>\n"
    }
  ],
  "categories": [
    "blocks"
  ],
  "$schema": "https://ui.shadcn.com/schema/registry-item.json"
}
